        await handleQuickBayesianOptimization();
      } else if (actionType === 'redesign') {
        // 调用重新设计API
        const result = await closedLoopApi.triggerRedesign({
          experiment_id: selectedExperiment,
          failure_reasons: ['能量密度未达标', '循环寿命需要提升'],
          iteration_count: 1
        });

